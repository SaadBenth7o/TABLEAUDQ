# ── Dremio connection ──────────────────────────────────────────────────────────
DREMIO_HOST=http://<host>:<port>

# Authentication type: "bearer" (PAT token) or "legacy" (username/password)
DREMIO_AUTH_TYPE=bearer
DREMIO_API_KEY=<your_personal_access_token>

# Only required when DREMIO_AUTH_TYPE=legacy
DREMIO_USERNAME=
DREMIO_PASSWORD=

# ── Scoring thresholds ─────────────────────────────────────────────────────────
SCORE_PASS_THRESHOLD=90
SCORE_WARN_THRESHOLD=70

# ── Source file ────────────────────────────────────────────────────────────────
EXCEL_FILE=Stewardship_Workshop_Template_Tiers_Counterparties.xlsx
EXCEL_SHEET=Quality_checks_poc

# ── Dremio publish target ─────────────────────────────────────────────────────
DREMIO_PUBLISH_AUTO=true
DREMIO_PUBLISH_HOME_NAME=@S141
DREMIO_PUBLISH_FOLDER_PATH=TiersDataQualityReport
DREMIO_PUBLISH_DATASET_NAME=all_columns_history
